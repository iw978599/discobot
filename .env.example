# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Server Configuration
# Local dev defaults to 3001 if PORT is not set.
# On Railway, PORT is injected automatically.
PORT=3001

# Origins allowed for browser UI requests (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional public UI URL (used as an allowed origin fallback)
PUBLIC_URL=https://your-app-name.up.railway.app
UI_URL=https://your-app-name.up.railway.app

# Optional persistent data directory for saved patterns (mount this on deploy)
PERSISTENCE_DIR=/data

# Bot -> Web API + WebSocket connection
WEB_API_URL=http://localhost:3001
WS_URL=ws://localhost:3001/ws/bot

# UI build-time WebSocket override (optional)
VITE_WS_URL=ws://localhost:3001/ws
